# =============================================================================
# CarpoolOrg — .gitignore
# Django 5.2 / Python 3.x project
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env.local
ENV/
env.bak/
venv.bak/

# ── Django ────────────────────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
db.sqlite3-shm
db.sqlite3-wal

# Media uploads (user-generated files — store in S3 / cloud in production)
media/

# Collected static files (generated by collectstatic)
staticfiles/

# Django secret key / sensitive settings
.env
.env.production
.env.staging
*.env

# ── Migrations (KEEP these in version control for team consistency) ───────────
# Do NOT add migrations/ here unless you have a good reason.

# ── Editors & IDEs ────────────────────────────────────────────────────────────
# VSCode
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# ── Operating System ──────────────────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~

# ── Testing & Coverage ────────────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
htmlcov/
.pytest_cache/
.cache/
nosetests.xml
test-results/

# ── Build & Distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
MANIFEST

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Redis (local dump) ────────────────────────────────────────────────────────
dump.rdb

# ── Node (if any frontend tooling is added later) ─────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.yarn/

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Type Checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── Rope (Python refactoring library) ─────────────────────────────────────────
.ropeproject/

# ── Documentation builds ──────────────────────────────────────────────────────
docs/_build/
site/

# ── Temporary & Misc ──────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
*.rej
*.patch
tmp/
temp/

.md